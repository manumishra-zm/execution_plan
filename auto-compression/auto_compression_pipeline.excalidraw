      "boundElements": null,
      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "REBUILD CONTRACT:  structure \u00b7 metadata \u00b7 relationships preserved  \u2192  only HEAVY assets (images / streams) replaced  \u2192  output is always the SAME format (never a .zip), smaller-or-same, never larger.  Internal unzip/extract\nis temporary only.",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "REBUILD CONTRACT:  structure \u00b7 metadata \u00b7 relationships preserved  \u2192  only HEAVY assets (images / streams) replaced  \u2192  output is always the SAME format (never a .zip), smaller-or-same, never larger.  Internal unzip/extract is temporary only.",
      "lineHeight": 1.25
    },
