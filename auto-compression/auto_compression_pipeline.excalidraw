      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "\u2462 BACKEND VALIDATION \u2014 upload.py\nauth \u00b7 RBAC upload:READ \u00b7 rate-limit 10/min \u00b7 feature + monthly-usage gate\nsize \u226410MB/file (spec \u00a76.1) \u00b7 \u22643 files & \u226430MB/session \u00b7 extension allowlist \u00b7 PDF pages \u226410 (fitz)\nreject oversize / bad type \u2192 user error (compression NOT attempted)",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "GA3",
      "originalText": "\u2462 BACKEND VALIDATION \u2014 upload.py\nauth \u00b7 RBAC upload:READ \u00b7 rate-limit 10/min \u00b7 feature + monthly-usage gate\nsize \u226410MB/file (spec \u00a76.1) \u00b7 \u22643 files & \u226430MB/session \u00b7 extension allowlist \u00b7 PDF pages \u226410 (fitz)\nreject oversize / bad type \u2192 user error (compression NOT attempted)",
      "lineHeight": 1.25
    },
