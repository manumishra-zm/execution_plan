      "boundElements": null,
      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "upload \u2192 validate \u2192 compress a COPY (thread) \u2192 store in GCS \u2192 OCR reads the ORIGINAL temp file \u00b7 sequential because PyMuPDF is not thread-safe",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "upload \u2192 validate \u2192 compress a COPY (thread) \u2192 store in GCS \u2192 OCR reads the ORIGINAL temp file \u00b7 sequential because PyMuPDF is not thread-safe",
      "lineHeight": 1.25
    },
