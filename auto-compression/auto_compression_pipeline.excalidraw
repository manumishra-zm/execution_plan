      "locked": false
    },
    {
      "id": "t366_109932",
      "type": "text",
      "x": 102,
      "y": 3314,
      "width": 409.3333333333333,
      "height": 116,
      "angle": 0,
      "strokeColor": "#1f2937",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 110023,
      "version": 2,
      "versionNonce": 110114,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "KEY RULES\n\u2022 silent \u00b7 invisible \u00b7 no UI change\n\u2022 MIN 500KB exempt \u00b7 MAX 10MB/file \u00b7 30MB & 3 files/session (spec\n\u00a76.1)\n\u2022 image \u2192 \u2264200KB/\u22641200px \u00b7 scanned PDF \u2192 \u2264300KB/page\n\u2022 heavy native PDF/DOCX/XLSX \u2192 embedded-image rebuild (flag)\n\u2022 pure-text / CSV / other \u2192 as-is \u00b7 filename+ext preserved\n\u2022 keep compressed only if < original \u00b7 fallback \u00b7 no retry",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "KEY RULES\n\u2022 silent \u00b7 invisible \u00b7 no UI change\n\u2022 MIN 500KB exempt \u00b7 MAX 10MB/file \u00b7 30MB & 3 files/session (spec \u00a76.1)\n\u2022 image \u2192 \u2264200KB/\u22641200px \u00b7 scanned PDF \u2192 \u2264300KB/page\n\u2022 heavy native PDF/DOCX/XLSX \u2192 embedded-image rebuild (flag)\n\u2022 pure-text / CSV / other \u2192 as-is \u00b7 filename+ext preserved\n\u2022 keep compressed only if < original \u00b7 fallback \u00b7 no retry",
      "lineHeight": 1.25
    },
    {
      "id": "rExec",
      "type": "rectangle",
      "x": 543.3333333333333,
      "y": 3304,
      "width": 433.3333333333333,
      "height": 168,
      "angle": 0,
      "strokeColor": "#e2e8f0",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1.5,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
