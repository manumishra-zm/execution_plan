    {
      "id": "t2_13563",
      "type": "text",
      "x": 80,
      "y": 62,
      "width": 1360,
      "height": 19,
      "angle": 0,
      "strokeColor": "#cbd5e1",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 13654,
      "version": 2,
      "versionNonce": 13745,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "OCR reads ORIGINAL \u00b7 compression runs on a COPY of in-memory bytes \u00b7 stores COMPRESSED copy \u00b7 same filename + extension \u00b7 internal unzip/rebuild only in temp \u00b7 fallback to original \u00b7 silent",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "OCR reads ORIGINAL \u00b7 compression runs on a COPY of in-memory bytes \u00b7 stores COMPRESSED copy \u00b7 same filename + extension \u00b7 internal unzip/rebuild only in temp \u00b7 fallback to original \u00b7 silent",
      "lineHeight": 1.25
    },
