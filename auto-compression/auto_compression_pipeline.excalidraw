      "versionNonce": 14200,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "LEGEND   \u25a0 control/frontend   \u25a0 library (no AI)   \u25a0 Gemini   \u25a0 compression   \u25a0 storage   \u25a0 preview   \u25a0 decision   \u25a0 fallback      SCOPE: green = compress now (image + scanned PDF)  \u00b7  amber = rebuild optional (native PDF / DOCX /\nXLSX, spec = skip)  \u00b7  grey = as-is",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "LEGEND   \u25a0 control/frontend   \u25a0 library (no AI)   \u25a0 Gemini   \u25a0 compression   \u25a0 storage   \u25a0 preview   \u25a0 decision   \u25a0 fallback      SCOPE: green = compress now (image + scanned PDF)  \u00b7  amber = rebuild optional (native PDF / DOCX / XLSX, spec = skip)  \u00b7  grey = as-is",
      "lineHeight": 1.25
    },
