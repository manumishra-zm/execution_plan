    {
      "id": "t364_109477",
      "type": "text",
      "x": 502,
      "y": 3092,
      "width": 766,
      "height": 61,
      "angle": 0,
      "strokeColor": "#1f2937",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 109568,
      "version": 2,
      "versionNonce": 109659,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "PREVIEW KEY POINTS\n\u2022 unpack happens ONLY in memory / temp \u00b7 never re-stored in ERPNext or GCS\n\u2022 the stored file IS the final compressed copy (smaller-or-same, same quality)\n\u2022 same route + same filename + same extension \u2192 content-type unchanged \u2192 renders normally \u00b7 NO .zip ever shown to the user",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PREVIEW KEY POINTS\n\u2022 unpack happens ONLY in memory / temp \u00b7 never re-stored in ERPNext or GCS\n\u2022 the stored file IS the final compressed copy (smaller-or-same, same quality)\n\u2022 same route + same filename + same extension \u2192 content-type unchanged \u2192 renders normally \u00b7 NO .zip ever shown to the user",
      "lineHeight": 1.25
    },
    {
      "id": "rRules",
      "type": "rectangle",
      "x": 90,
      "y": 3304,
      "width": 433.3333333333333,
      "height": 168,
      "angle": 0,
      "strokeColor": "#e2e8f0",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1.5,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
