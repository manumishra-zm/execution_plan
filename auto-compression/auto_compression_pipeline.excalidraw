      "boundElements": null,
      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "\u2466 PERSIST (deferred until AFTER compression + validation)\noverwrite the single upload_bytes write in _save_original_file \u2192\nGCS  sessions/{session_id}/originals/{filename}  (SAME name + ext, in place)\n+ save OCR outputs .json / .md / .txt \u2192 sessions/{session_id}/\n+ ALSO persists the \u00a77 heavy-native rebuild result \u25bc",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "GA6",
      "originalText": "\u2466 PERSIST (deferred until AFTER compression + validation)\noverwrite the single upload_bytes write in _save_original_file \u2192\nGCS  sessions/{session_id}/originals/{filename}  (SAME name + ext, in place)\n+ save OCR outputs .json / .md / .txt \u2192 sessions/{session_id}/\n+ ALSO persists the \u00a77 heavy-native rebuild result \u25bc",
      "lineHeight": 1.25
    },
