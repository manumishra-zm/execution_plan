      "link": null,
      "locked": false
    },
    {
      "id": "t368_110387",
      "type": "text",
      "x": 555.3333333333333,
      "y": 3314,
      "width": 409.3333333333333,
      "height": 116,
      "angle": 0,
      "strokeColor": "#1f2937",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 110478,
      "version": 2,
      "versionNonce": 110569,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1718000000000,
      "link": null,
      "locked": false,
      "text": "EXECUTION MODEL (reality)\n\u2022 OCR is SYNCHRONOUS inline (await wait_for 300s)\n\u2022 NO queue / worker / BackgroundTasks today\n\u2022 compression runs SEQUENTIALLY before OCR\n(PyMuPDF is single-threaded \u2192 no concurrent fitz)\n\u2022 CPU work offloaded to asyncio.to_thread\n(doesn't block OTHER requests)\n\u2022 true background compression = NET-NEW infra",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "EXECUTION MODEL (reality)\n\u2022 OCR is SYNCHRONOUS inline (await wait_for 300s)\n\u2022 NO queue / worker / BackgroundTasks today\n\u2022 compression runs SEQUENTIALLY before OCR\n  (PyMuPDF is single-threaded \u2192 no concurrent fitz)\n\u2022 CPU work offloaded to asyncio.to_thread\n  (doesn't block OTHER requests)\n\u2022 true background compression = NET-NEW infra",
      "lineHeight": 1.25
    },
